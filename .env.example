# Supabase — 프로젝트 대시보드에서 복사해 `.env.local`에 붙여넣기
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 배포 URL (OG 등 절대 URL용, 로컬은 생략 가능)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# site_content 후원 키 — /admin/content(후원 문구)에서 편집
# donate_bank_info, donate_external_url, donate_external_label,
# donate_contact_email, donate_contact_phone, donate_contact_note, donate_ways_intro
#
# DB 스키마: supabase/migrations/20260418120000_childrens_nest_init.sql
# 어드민 글 CRUD(RLS): supabase/migrations/20260419120000_posts_authenticated_crud.sql
# site_content 후원 문구 쓰기(RLS): supabase/migrations/20260420120000_site_content_authenticated_write.sql
# Storage media 버킷 + 홈 문구 site_content + RLS 확장: supabase/migrations/20260421130000_storage_media_home_site_content.sql
